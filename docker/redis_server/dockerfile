# Use the official Redis image from the Docker Hub
FROM redis/redis-stack-server:7.4.0-v3

# Copy the custom redis.conf file
COPY redis.conf /usr/local/etc/redis/redis.conf

# Expose the default Redis port
EXPOSE 6379

USER root

# redis-stack-server image doesn't include a redis user (unlike the standard redis image)
RUN groupadd -r redis && useradd -r -g redis redis

COPY init.sh /init.sh
RUN chmod +x /init.sh
ENTRYPOINT ["/init.sh"]