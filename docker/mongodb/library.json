{
  "libraryItemId": "mongodb",
  "name": "MongoDB",
  "language": "docker",
  "tags": {
    "Category": ["Database"],
    "Type": ["Auxiliary Services"]
  },
  "shortDescription": "Run MongoDB in your pipeline.",
  "DefaultFile": "dockerfile",
  "EntryPoint": "dockerfile",
  "IconFile": "icon.png",
  "DeploySettings": {
    "DeploymentType": "Service",
    "CpuMillicores": 200,
    "MemoryInMb": 800,
    "Replicas": 1,
    "Network": {
      "ServiceName": "mongodb",
      "Ports":
      [
        {
          "Port": 27017,
          "TargetPort": 27017
        }
      ]
    }
  },
  "Variables": [
    {
      "Name": "MONGODB_CONNECTION",
      "InputType": "VariableGroup",
      "Description": "MongoDB root credentials sourced from a shared Variable Group, injected as env vars at deploy.",
      "VariableGroupId": "mongodb-connection",
      "VariableGroupName": "MongoDB Connection",
      "VariableGroupDescription": "Shared MongoDB connection credentials.",
      "Required": true,
      "Variables": [
        {
          "Key": "MONGO_INITDB_ROOT_USERNAME",
          "Description": "The root username to initialize MongoDB with",
          "DefaultValue": "admin",
          "Secret": false,
          "Required": true
        },
        {
          "Key": "MONGO_INITDB_ROOT_PASSWORD",
          "Description": "The root password to initialize MongoDB with",
          "DefaultValue": "",
          "Secret": true,
          "Required": true
        }
      ]
    }
  ]
}
